# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Gerado automaticamente pelo Railway ao adicionar PostgreSQL
# Desenvolvimento local: postgresql://postgres:dev@localhost:5432/nexora_dev
DATABASE_URL=

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=
# URL pública da aplicação
NEXTAUTH_URL=http://localhost:3000

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=nexora-edu
# URL pública do bucket (se habilitado) ou endpoint da API
CLOUDFLARE_R2_PUBLIC_URL=

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Desenvolvimento local: redis://localhost:6379
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ─── Resend (emails) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@nexora.edu

# ─── Digisac (WhatsApp) ───────────────────────────────────────────────────────
DIGISAC_TOKEN=
DIGISAC_SUBDOMAIN=

# ─── Omie (ERP financeiro) ────────────────────────────────────────────────────
OMIE_APP_KEY=
OMIE_APP_SECRET=

# ─── Groq (chatbot NLP) ───────────────────────────────────────────────────────
GROQ_API_KEY=

# ─── Puppeteer (geração de certificados PDF) ──────────────────────────────────
# Deixar vazio para usar Chromium padrão; preencher em produção Railway/Docker
PUPPETEER_EXECUTABLE_PATH=

# ─── Sentry (monitoramento de erros) ─────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Apenas para upload de source maps no CI — nunca expor em runtime
SENTRY_AUTH_TOKEN=

# ─── Identidade visual ────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME=Nexora EDU
NEXT_PUBLIC_BRAND_TAGLINE=Educação sem fronteiras
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@nexora.edu
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_DOCS_URL=

# ─── Botão de apoio ───────────────────────────────────────────────────────────
# Preencher apenas as plataformas que deseja exibir
NEXT_PUBLIC_SUPPORT_GITHUB_SPONSORS=
NEXT_PUBLIC_SUPPORT_LIVEPIX=
NEXT_PUBLIC_SUPPORT_KO_FI=
NEXT_PUBLIC_SUPPORT_BUY_ME_COFFEE=
NEXT_PUBLIC_SUPPORT_PIX_KEY=

# ─── Backup (se Railway plano gratuito) ───────────────────────────────────────
BACKUP_R2_BUCKET=nexora-edu-backups
BACKUP_RETENTION_DAYS=30

# ─── Cron jobs ───────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
CRON_SECRET=

# ─── Ambiente ────────────────────────────────────────────────────────────────
NODE_ENV=development
