// packages/db/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── IDENTIDADE ──────────────────────────────────────────────────────────────

/// Cadastro único global — independente do tenant.
/// CPF opcional para suportar casos cross-tenant (professor Inst.B sem CPF matriculado na Inst.A).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  /// Hash Argon2 — nunca texto plano
  passwordHash String
  name         String
  /// Opcional: vínculo cross-tenant é feito por email; CPF pode ser complementado depois
  cpf          String?  @unique
  /// Telefone no formato E.164 sem '+' (ex: "5511999999999") — usado para WhatsApp via Digisac
  phone        String?
  avatarUrl    String?
  /// Data de aceite dos termos e política de privacidade (LGPD). Null = não consentiu ainda.
  consentedAt  DateTime?
  /// Null = conta ativa. Preenchido quando usuário solicita exclusão de dados (LGPD art. 18).
  anonymizedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships      TenantMembership[]
  auditLogs        AuditLog[]
  onboarding       UserOnboarding[]
  announcements    Announcement[]
  forumThreads     ForumThread[]    @relation("ForumThreadAuthor")
  forumReplies     ForumReply[]     @relation("ForumReplyAuthor")
  sentMessages     DirectMessage[]  @relation("DMSender")
  receivedMessages DirectMessage[]  @relation("DMReceiver")
  turmaEnrollments TurmaEnrollment[] @relation("StudentTurmaEnrollments")

  @@index([email])
}

/// Vínculo entre usuário, tenant e papel.
/// Um usuário pode ter múltiplos vínculos (ex: professor Inst.B + aluno Inst.A).
model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  /// 'inst_a' | 'inst_b' — expansível para novos tenants
  tenantId  String
  role      Role
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, role])
  @@index([tenantId, role])
  @@index([userId, tenantId])
}

enum Role {
  ALUNO
  PROFESSOR
  COORDENADOR
  ADMIN
  SUPER_ADMIN
}

// ─── EAD ─────────────────────────────────────────────────────────────────────

model Course {
  id          String       @id @default(cuid())
  tenantId    String
  slug        String
  title       String
  description String?
  status      CourseStatus @default(DRAFT)
  hoursTotal  Int          @default(0)
  /// false = curso de Teste (pode ser excluído em cascata); true = Oficial (exclusão bloqueada)
  isOfficial  Boolean      @default(false)
  /// Fórmula da nota final ponderando as avaliações (ex: "(p1*0.4)+(p2*0.6)").
  /// Avaliada com mathjs — NUNCA eval. Variáveis vêm de Assessment.formulaVar.
  gradeFormula String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  modules       Module[]
  enrollments   Enrollment[]
  assessments   Assessment[]
  announcements Announcement[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Module {
  id    String @id @default(cuid())
  courseId String
  title    String
  /// Posição para ordenação drag-and-drop
  position Int
  /// ID do módulo que deve estar concluído antes de desbloquear este
  prerequisiteId String?

  course   Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
  threads  ForumThread[]

  @@index([courseId, position])
}

model Lesson {
  id       String     @id @default(cuid())
  moduleId String
  title    String
  type     LessonType
  position Int
  /// Para tipo VIDEO: ID interno — videoId do YouTube resolvido server-side, nunca exposto ao client
  videoRef String?
  /// Para tipo PDF: chave no Cloudflare R2
  fileKey  String?
  /// Para tipo TEXT: conteúdo rico em markdown/html
  content  String?
  /// Para tipo LINK: URL externa
  url      String?
  duration Int? // segundos

  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  liveSession LiveSession?

  @@index([moduleId, position])
}

/// Sessão ao vivo vinculada a uma aula do tipo LIVE.
model LiveSession {
  id         String          @id @default(cuid())
  tenantId   String
  lessonId   String          @unique
  /// URL da reunião: Zoom, Google Meet, Teams, etc.
  meetingUrl String
  /// Data/hora de início agendada
  startAt    DateTime
  /// Duração prevista em minutos
  durationMin Int            @default(60)
  status     LiveStatus      @default(SCHEDULED)
  /// Link da gravação no YouTube após o evento
  recordingUrl String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  lesson     Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attendances LiveAttendance[]

  @@index([tenantId, startAt])
  @@index([tenantId, status])
}

enum LiveStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

/// Registro de presença de um aluno numa sessão ao vivo.
model LiveAttendance {
  id            String      @id @default(cuid())
  liveSessionId String
  enrollmentId  String
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, enrollmentId])
  @@index([liveSessionId])
}

enum LessonType {
  VIDEO
  PDF
  TEXT
  LINK
  LIVE
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  courseId  String
  tenantId  String
  status    EnrollmentStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([userId, courseId])
  @@index([tenantId, status])
  @@index([expiresAt])
  @@index([userId])
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

model LessonProgress {
  id           String    @id @default(cuid())
  enrollmentId String
  lessonId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  /// Segundos assistidos — para marcar conclusão automática por tempo
  watchedSecs  Int       @default(0)

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

// ─── AVALIAÇÕES ──────────────────────────────────────────────────────────────

model Assessment {
  id           String           @id @default(cuid())
  tenantId     String
  courseId     String
  /// Módulo ao qual a avaliação pertence (opcional)
  moduleId     String?
  title        String
  description  String?
  status       AssessmentStatus @default(DRAFT)
  /// Nota mínima de aprovação, na mesma escala da soma de pontos das questões
  passingScore Float            @default(6)
  /// Tentativas máximas permitidas ao aluno
  maxAttempts  Int              @default(1)
  dueAt        DateTime?
  /// Nome da variável desta avaliação na fórmula de nota final (ex: "p1")
  formulaVar   String?
  /// Quando esta avaliação é a recuperação de outra
  recoveryOfId String?          @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  recoveryOf  Assessment?  @relation("Recovery", fields: [recoveryOfId], references: [id])
  recovery    Assessment?  @relation("Recovery")
  questions   Question[]
  submissions Submission[]

  @@index([tenantId, courseId])
  @@index([courseId, status])
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Question {
  id           String       @id @default(cuid())
  assessmentId String
  type         QuestionType
  /// Enunciado da questão (texto/markdown)
  prompt       String
  /// Peso da questão na nota da avaliação
  points       Float        @default(1)
  position     Int
  /// MULTIPLE_CHOICE: array de { id, text }
  options      Json?
  /// Gabarito: MC = id(s) da opção; TRUE_FALSE = boolean; ESSAY = null (correção manual)
  correctAnswer Json?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, position])
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  ESSAY
}

model Submission {
  id           String           @id @default(cuid())
  tenantId     String
  assessmentId String
  enrollmentId String
  attempt      Int              @default(1)
  status       SubmissionStatus @default(IN_PROGRESS)
  /// Respostas do aluno: { [questionId]: resposta }
  answers      Json
  /// Arquivos entregues (chaves de storage): string[]
  fileKeys     Json?
  /// Nota final após correção (auto + dissertativas)
  score        Float?
  gradedAt     DateTime?
  gradedBy     String?
  createdAt    DateTime         @default(now())
  submittedAt  DateTime?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, enrollmentId, attempt])
  @@index([tenantId, assessmentId])
  @@index([enrollmentId])
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

// ─── PAGE BUILDER ─────────────────────────────────────────────────────────────

/// Layout de página editado pelo page builder.
/// blocks é um JSON array de LayoutBlock[] — validado na API via Zod, nunca no banco.
model PageLayout {
  id        String    @id @default(cuid())
  tenantId  String
  /// 'home' | 'course' | 'login' | 'certificate' | custom
  pageType  String
  version   Int
  blocks    Json
  /// null = rascunho não publicado
  publishedAt DateTime?
  updatedAt   DateTime  @updatedAt
  updatedBy   String

  @@index([tenantId, pageType, version])
  @@index([tenantId, pageType, publishedAt])
}

// ─── CERTIFICADOS ─────────────────────────────────────────────────────────────

/// Certificado emitido ao concluir um curso.
/// O código único é usado para validação pública em /certificado/{code}.
model Certificate {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  courseId     String
  enrollmentId String
  /// Código alfanumérico único para validação pública — gerado com crypto.randomUUID()
  code         String   @unique
  /// Chave no R2 onde o PDF está armazenado
  pdfKey       String?
  issuedAt     DateTime @default(now())

  @@index([tenantId, userId])
  @@index([code])
}

// ─── AUDITORIA ────────────────────────────────────────────────────────────────

// ─── COMUNICAÇÃO ─────────────────────────────────────────────────────────────

/// Aviso publicado pelo admin — visível a todos os alunos do escopo.
model Announcement {
  id        String             @id @default(cuid())
  tenantId  String
  authorId  String
  scope     AnnouncementScope  @default(PLATFORM)
  /// courseId obrigatório quando scope = COURSE
  courseId  String?
  title     String
  body      String
  pinned    Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  author User    @relation(fields: [authorId], references: [id])
  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId, scope, createdAt])
  @@index([tenantId, courseId])
}

enum AnnouncementScope {
  PLATFORM
  COURSE
}

/// Tópico de fórum ligado a um módulo de curso.
model ForumThread {
  id        String   @id @default(cuid())
  tenantId  String
  moduleId  String
  authorId  String
  title     String
  body      String
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module  Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  author  User          @relation("ForumThreadAuthor", fields: [authorId], references: [id])
  replies ForumReply[]

  @@index([tenantId, moduleId, createdAt])
}

/// Resposta a um tópico de fórum. Suporta 1 nível de aninhamento (parentId).
model ForumReply {
  id        String   @id @default(cuid())
  tenantId  String
  threadId  String
  authorId  String
  parentId  String?
  body      String
  createdAt DateTime @default(now())

  thread  ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User         @relation("ForumReplyAuthor", fields: [authorId], references: [id])
  parent  ForumReply?  @relation("ReplyTree", fields: [parentId], references: [id])
  replies ForumReply[] @relation("ReplyTree")

  @@index([tenantId, threadId, createdAt])
}

/// Mensagem direta aluno ↔ admin. Agrupadas por threadId.
model DirectMessage {
  id         String   @id @default(cuid())
  tenantId   String
  threadId   String
  senderId   String
  receiverId String
  body       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  sender   User @relation("DMSender",   fields: [senderId],   references: [id])
  receiver User @relation("DMReceiver", fields: [receiverId], references: [id])

  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, receiverId, readAt])
}

/// Entrada da base de conhecimento usada pelo chatbot como contexto RAG.
model KnowledgeEntry {
  id        String   @id @default(cuid())
  tenantId  String
  question  String
  answer    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
}

// ─── AUDITORIA ────────────────────────────────────────────────────────────────

/// Log imutável de ações relevantes. Nunca deletar registros — apenas arquivar.
model AuditLog {
  id       String  @id @default(cuid())
  tenantId String
  userId   String
  /// Ex: 'enrollment.create', 'layout.publish', 'lesson.access', 'user.login'
  action   String
  /// Ex: 'enrollment:cuid123'
  resource String?
  /// Dados adicionais da ação em JSON livre
  meta     Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, action, createdAt])
  @@index([userId, createdAt])
}

// ─── ONBOARDING ──────────────────────────────────────────────────────────────

/// Rastreia quais tours o usuário já completou ou pulou.
/// Persistido no banco (não em cookie) para funcionar entre dispositivos.
model UserOnboarding {
  id          String    @id @default(cuid())
  userId      String
  tourId      String
  completed   Boolean   @default(false)
  skipped     Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
  @@index([userId])
}

// ─── INTEGRAÇÕES ──────────────────────────────────────────────────────────────

/// Template de mensagem WhatsApp por evento, configurável pelo admin por tenant.
/// bodyTemplate usa {{placeholders}}: {{name}}, {{course}}, {{date}}, {{link}}, etc.
model WhatsAppTemplate {
  id           String       @id @default(cuid())
  tenantId     String
  event        String
  /// Texto do template com {{placeholders}}
  bodyTemplate String
  isActive     Boolean      @default(true)
  updatedAt    DateTime     @updatedAt
  updatedBy    String

  @@unique([tenantId, event])
  @@index([tenantId, isActive])
}

/// Rastreia a sincronização de uma matrícula com o Omie ERP.
model OmieSync {
  id                 String    @id @default(cuid())
  enrollmentId       String    @unique
  tenantId           String
  /// ID do cliente no Omie (codigo_cliente_omie)
  omieClientId       String?
  /// ID da conta a receber no Omie
  omieReceivableId   String?
  status             OmieSyncStatus @default(PENDING)
  lastSyncedAt       DateTime?
  errorMessage       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([enrollmentId])
}

enum OmieSyncStatus {
  PENDING
  SYNCED
  FAILED
}

// ─── LGPD ─────────────────────────────────────────────────────────────────────

/// Exportação de dados pessoais solicitada pelo usuário (art. 18 LGPD).
/// O arquivo JSON é armazenado no R2 com presigned URL válida por 24h.
model UserDataExport {
  id        String             @id @default(cuid())
  userId    String
  tenantId  String
  status    DataExportStatus   @default(PENDING)
  /// Chave do arquivo JSON no R2 (vazia enquanto PENDING)
  r2Key     String?
  /// Momento em que a URL expira (now + 24h)
  expiresAt DateTime?
  createdAt DateTime           @default(now())

  @@index([userId])
  @@index([tenantId, status])
}

enum DataExportStatus {
  PENDING
  READY
  EXPIRED
}

// ─── SECRETARIA ───────────────────────────────────────────────────────────────

/// Unidade física da escola (ex: "Colinas", "Caminhos", "Principal").
/// Escolas com uma única unidade criam uma unidade "Principal".
/// A unidade determina a identidade de gênero para escolas single-sex.
model Unidade {
  id        String        @id @default(cuid())
  tenantId  String
  /// Nome exibido: "Colinas", "Caminhos", "Principal"
  name      String
  /// Código curto usado nos códigos de turma: "COL", "CAM", ""
  code      String
  gender    UnidadeGender @default(MISTO)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  turmas    Turma[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
}

enum UnidadeGender {
  MASCULINO
  FEMININO
  MISTO
}

/// Ano letivo. Todas as turmas pertencem a um ano letivo.
model AnoLetivo {
  id        String          @id @default(cuid())
  tenantId  String
  year      Int
  startDate DateTime
  endDate   DateTime
  status    AnoLetivoStatus @default(PLANEJADO)
  createdAt DateTime        @default(now())

  turmas    Turma[]

  @@unique([tenantId, year])
  @@index([tenantId, status])
}

enum AnoLetivoStatus {
  PLANEJADO
  EM_ANDAMENTO
  ENCERRADO
}

/// Turma de uma unidade em um ano letivo.
/// O código é gerado automaticamente a partir da etapa + ano + letra + unidade:
///   EFAICCC → "EFAICCC1A" (anos 1-2, misto)
///   EFAI    → "EFAI3ACOL"
///   EFAF    → "EFAF6BCAM"
///   EM      → "EM2BCOL"
/// Para escolas comuns (unidade code = ""), o código omite o sufixo: "EFAI3A"
model Turma {
  id          String   @id @default(cuid())
  tenantId    String
  unidadeId   String
  anoLetivoId String
  /// Código único dentro do ano letivo: "EFAI3ACOL", "EM2BCAM", "EFAICCC1A"
  code        String
  etapa       Etapa
  /// Ano dentro da etapa: 1-5 (EFAI/EFAICCC), 6-9 (EFAF), 1-3 (EM)
  ano         Int
  /// Letra da turma: "A", "B", "C" ...
  letra       String
  periodo     Periodo  @default(MANHA)
  maxStudents Int      @default(35)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unidade     Unidade         @relation(fields: [unidadeId], references: [id])
  anoLetivo   AnoLetivo       @relation(fields: [anoLetivoId], references: [id])
  enrollments TurmaEnrollment[]
  disciplinas TurmaDisciplina[]

  @@unique([tenantId, anoLetivoId, code])
  @@index([tenantId, anoLetivoId])
  @@index([unidadeId, etapa])
}

enum Etapa {
  /// Educação Infantil
  EI
  /// Ensino Fundamental Anos Iniciais (séries 1-5)
  EF1
  /// Ensino Fundamental Anos Finais (séries 6-9)
  EF2
  /// Ensino Médio (anos 1-3)
  EM
}

enum Periodo {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

/// Matrícula de um aluno em uma turma (Secretaria, distinto de Enrollment EAD).
model TurmaEnrollment {
  id          String                @id @default(cuid())
  tenantId    String
  studentId   String
  turmaId     String
  /// Denormalizado para facilitar consultas históricas por ano letivo
  anoLetivoId String
  status      TurmaEnrollmentStatus @default(ATIVA)
  enrolledAt  DateTime              @default(now())
  cancelledAt DateTime?
  notes       String?

  turma       Turma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  student     User         @relation("StudentTurmaEnrollments", fields: [studentId], references: [id])
  grades      Grade[]
  attendances Attendance[]

  /// Um aluno só pode estar em uma turma por ano letivo
  @@unique([studentId, anoLetivoId])
  @@index([tenantId, turmaId])
  @@index([tenantId, anoLetivoId])
  @@index([studentId])
}

enum TurmaEnrollmentStatus {
  ATIVA
  TRANSFERIDA
  CANCELADA
  CONCLUIDA
}

/// Responsável/guardian de um aluno menor de idade.
/// userId é opcional: quando preenchido, o responsável tem acesso ao portal.
model Guardian {
  id           String               @id @default(cuid())
  tenantId     String
  /// userId do aluno (User)
  studentId    String
  name         String
  email        String?
  phone        String?
  cpf          String?
  relationship GuardianRelationship
  isPrimary    Boolean              @default(false)
  /// Quando preenchido, este responsável tem login no portal
  userId       String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([tenantId, studentId])
  @@index([studentId])
}

enum GuardianRelationship {
  PAI
  MAE
  RESPONSAVEL
  OUTRO
}

// ─── PEDAGÓGICO ───────────────────────────────────────────────────────────────

/// Disciplina de uma etapa (ex: "Matemática"). Pode ter frentes — sub-disciplinas
/// graduadas separadamente (ex: "Matemática 1", "Matemática 2"). Frente = Disciplina
/// com parentId preenchido. No boletim, pai e frentes aparecem como linhas próprias.
model Disciplina {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  /// null = disciplina raiz; preenchido = frente de outra disciplina
  parentId  String?
  /// Ordem de exibição no boletim
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  parent           Disciplina?       @relation("Frentes", fields: [parentId], references: [id], onDelete: Cascade)
  frentes          Disciplina[]      @relation("Frentes")
  turmaDisciplinas TurmaDisciplina[]
  grades           Grade[]
  attendances      Attendance[]

  @@index([tenantId, parentId])
  @@index([tenantId, active])
}

/// Vínculo disciplina ↔ turma (quais disciplinas a turma cursa).
model TurmaDisciplina {
  id           String @id @default(cuid())
  tenantId     String
  turmaId      String
  disciplinaId String

  turma      Turma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@unique([turmaId, disciplinaId])
  @@index([tenantId, turmaId])
}

/// Nota de um aluno numa disciplina, por período (trimestre) e tipo de avaliação.
model Grade {
  id           String    @id @default(cuid())
  tenantId     String
  enrollmentId String
  disciplinaId String
  /// 1, 2, 3 = trimestre; usado com kind para localizar a célula do boletim
  period       Int
  kind         GradeKind
  score        Float?
  updatedAt    DateTime  @updatedAt
  updatedBy    String

  enrollment TurmaEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  disciplina Disciplina      @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, disciplinaId, period, kind])
  @@index([tenantId, enrollmentId])
  @@index([disciplinaId])
}

enum GradeKind {
  /// Avaliação do trimestre
  AVA
  /// Recuperação do trimestre
  RECP
  /// Prova final
  FINAL
}

/// Frequência: faltas acumuladas de um aluno numa disciplina.
model Attendance {
  id           String   @id @default(cuid())
  tenantId     String
  enrollmentId String
  disciplinaId String
  absences     Int      @default(0)
  updatedAt    DateTime @updatedAt

  enrollment TurmaEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  disciplina Disciplina      @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, disciplinaId])
  @@index([tenantId, enrollmentId])
}
